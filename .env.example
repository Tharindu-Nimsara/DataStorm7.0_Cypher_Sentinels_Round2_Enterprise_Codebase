# Copy this file to `.env` and fill in your values. `.env` is gitignored — never commit it.
# Only the XAI explanation layer (src/xai_explain.py) needs these; the rest of the pipeline
# runs without any secrets. With no token, xai_explain.py uses the deterministic offline
# template for every outlet, so the full pipeline still works end-to-end.

# GitHub Models token (a GitHub PAT with the "Models" account permission: read).
# Powers the live LLM explanations in Phase 4. Without it, explanations fall back to the
# grounded offline template.
GITHUB_TOKEN=

# Optional overrides (sensible defaults are baked in):
# XAI_MODEL=gpt-4o-mini
# XAI_ENDPOINT=https://models.inference.ai.azure.com
# XAI_LIVE_SAMPLE=15
