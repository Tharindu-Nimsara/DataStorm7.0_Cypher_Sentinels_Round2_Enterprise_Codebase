# Data artifacts — regenerated by the pipeline, never committed.
data/
# but keep the folder structure so the pipeline has somewhere to write
!data/.gitkeep

# Secrets — never commit. GITHUB_TOKEN for the XAI LLM layer lives here.
.env

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
venv/
env/

# Logs and trained model binary — regenerate via the pipeline scripts.
logs/
models/

# Report intermediates — ship the PDFs, keep working source local.
# (figures regenerate; report.md/html are prelim scratch; genai_log.md is the
# old lowercase prelim log — the tracked final-round log is GENAI_LOG.md.)
reports/figures/
reports/genai_log.md
reports/report.md
reports/report.html

# Written deliverables (the paper & deck) are submitted via the entry form, not
# tracked in the code repo — and their drafts/build helpers stay local.
reports/paper.*
reports/deck.*
notebooks/build_paper_html.py
notebooks/build_deck_html.py

# AI-collaboration files — kept local, not part of the public repo.
CLAUDE.md
SOLO_PLAYBOOK.md
tasks.md
.claude/
paper_tasks.md
deck_tasks.md

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Build / dist — the submission zip is generated by make_repro_zip.py, not committed.
.dist/
dist/
*.egg-info/
